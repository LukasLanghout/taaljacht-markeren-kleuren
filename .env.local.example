# Kopieer dit bestand naar .env.local en vul echte waarden in.
# .env.local staat in .gitignore en wordt NIET gecommit.

NEXT_PUBLIC_SUPABASE_URL=https://jouw-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=jouw-anon-key-hier

# Groq API-sleutel (voor tekst-analyse): https://console.groq.com/keys
GROQ_API_KEY=gsk_jouw-groq-key-hier

# Google Gemini API-sleutel (voor OCR op ingescande PDFs): https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza_jouw-gemini-key-hier
