# Google Gemini API key — voor OCR (gemini-2.5-flash-lite) en opdracht-extractie (gemini-2.5-flash)
# Maak een key aan op: https://aistudio.google.com/apikey
GEMINI_API_KEY=jouw_gemini_api_key_hier

# Supabase project URL en anon-key
# Te vinden in je Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=jouw_supabase_anon_key_hier
